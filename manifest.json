{
  "manifest_version": 3,
  "name": "Ganj's Utility Belt",
  "version": "3.0",
  "description": "Developer productivity suite: Pomodoro timer, tab management, sticky notes, CSS/JS editors, screenshot tools, color utilities, text tools, auto-refresh, cross-tab search, and more.",
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "alarms",
    "tabs",
    "tabGroups",
    "scripting",
    "storage",
    "activeTab",
    "contextMenus",
    "notifications",
    "clipboardWrite",
    "bookmarks"
  ],
  "options_page": "options.html",
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "css": ["content-styles.css"],
    "js": [
      "modules/constants.js",
      "libs/marked.min.js",
      "modules/stickyNotes.js",
      "modules/pomodoro.js",
      "modules/pomodoroOverlay.js",
      "modules/quickActions.js",
      "modules/autoRefresh.js",
      "modules/crossTabSearch.js",
      "modules/cssEditor.js",
      "modules/jsEditor.js",
      "modules/screenshotTools.js",
      "modules/colorTools.js",
      "modules/textTools.js",
      "modules/imageMagnifier.js",
      "modules/redirector.js",
      "modules/networkTools.js",
      "modules/dataTools.js",
      "modules/mediaScanner.js"
    ],
    "run_at": "document_idle"
  }],
  "web_accessible_resources": [{
    "resources": [
      "icon.png",
      "libs/ace/*.js",
      "libs/beautify.js",
      "libs/beautify-css.js"
    ],
    "matches": ["<all_urls>"]
  }]
}
